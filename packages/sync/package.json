{
  "name": "@rudderjs/sync",
  "version": "1.8.0",
  "description": "Real-time collaborative document sync engine for RudderJS — Yjs CRDT over WebSocket, with a Lexical editor adapter under a subpath export.",
  "rudderjs": {
    "provider": "SyncProvider",
    "stage": "feature"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rudderjs/rudder",
    "directory": "packages/sync"
  },
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "files": [
    "dist",
    "schema",
    "boost"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./collab": {
      "import": "./dist/collab/index.js",
      "types": "./dist/collab/index.d.ts"
    },
    "./lexical": {
      "import": "./dist/lexical/index.js",
      "types": "./dist/lexical/index.d.ts"
    },
    "./react": {
      "import": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/index.test.js dist-test/database-persistence.test.js dist-test/persistence-errors.test.js dist-test/room-id.test.js dist-test/collab/index.test.js dist-test/collab/seed.test.js dist-test/awareness-removal.test.js dist-test/lexical/index.test.js dist-test/ssr-hydration.test.js dist-test/react/CollabRoomManager.test.js dist-test/react/useCollabSeed.test.js dist-test/react/presence.test.js"
  },
  "dependencies": {
    "@rudderjs/core": "workspace:^",
    "yjs": "^13.6.0",
    "ws": "^8.0.0",
    "lib0": "^0.2.0"
  },
  "peerDependencies": {
    "react": ">=19.2.0",
    "y-websocket": "^2.0.0 || ^3.0.0",
    "y-indexeddb": "^9.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "y-websocket": {
      "optional": true
    },
    "y-indexeddb": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "ioredis": "^5.3.0",
    "@prisma/client": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.0.0",
    "react": "^19.2.0",
    "@types/react": "^19.2.0",
    "y-websocket": "^3.0.0",
    "y-indexeddb": "^9.0.0",
    "typescript": "^5.4.0"
  },
  "author": "Suleiman Shahbari"
}
