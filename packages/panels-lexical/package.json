{
  "name": "@boostkit/panels-lexical",
  "version": "0.0.1",
  "description": "Lexical rich-text editor adapter for @boostkit/panels",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/boostkitjs/boostkit",
    "directory": "packages/panels-lexical"
  },
  "type": "module",
  "files": ["dist"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {},
  "peerDependencies": {
    "@boostkit/panels": "workspace:*",
    "react": ">=18",
    "lexical": ">=0.20",
    "@lexical/react": ">=0.20",
    "@lexical/rich-text": ">=0.20",
    "@lexical/list": ">=0.20",
    "@lexical/link": ">=0.20",
    "@lexical/code": ">=0.20",
    "@lexical/utils": ">=0.20",
    "@floating-ui/dom": ">=1",
    "yjs": ">=13",
    "y-websocket": ">=2"
  },
  "peerDependenciesMeta": {
    "yjs": { "optional": true },
    "y-websocket": { "optional": true }
  },
  "devDependencies": {
    "@boostkit/panels": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "lexical": "^0.41.0",
    "@lexical/react": "^0.41.0",
    "@lexical/rich-text": "^0.41.0",
    "@lexical/list": "^0.41.0",
    "@lexical/link": "^0.41.0",
    "@lexical/code": "^0.41.0",
    "@lexical/utils": "^0.41.0",
    "@floating-ui/dom": "^1.6.0",
    "react": "^19.0.0",
    "typescript": "^5.4.0",
    "yjs": "^13.6.29",
    "y-websocket": "^2.1.0"
  },
  "author": "Suleiman Shahbari"
}
