{
  "name": "@rudderjs/orm",
  "version": "1.16.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rudderjs/rudder",
    "directory": "packages/orm"
  },
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "files": [
    "dist",
    "boost"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./db-bridge": {
      "node": "./dist/db-bridge.js",
      "import": "./dist/db-bridge.js",
      "default": "./dist/db-bridge.js",
      "types": "./dist/db-bridge.d.ts"
    },
    "./sticky": {
      "node": "./dist/sticky.js",
      "import": "./dist/sticky.js",
      "default": "./dist/sticky.js",
      "types": "./dist/sticky.d.ts"
    },
    "./native": {
      "node": "./dist/native/index.js",
      "import": "./dist/native/index.js",
      "default": "./dist/native/index.js",
      "types": "./dist/native/index.d.ts"
    },
    "./native/provider": {
      "node": "./dist/native/provider.js",
      "import": "./dist/native/provider.js",
      "default": "./dist/native/provider.js",
      "types": "./dist/native/provider.d.ts"
    },
    "./doctor": {
      "import": "./dist/doctor.js",
      "default": "./dist/doctor.js",
      "types": "./dist/doctor.d.ts"
    },
    "./commands/migrate": {
      "import": "./dist/commands/migrate.js",
      "types": "./dist/commands/migrate.d.ts"
    },
    "./commands/schema-types": {
      "import": "./dist/commands/schema-types.js",
      "types": "./dist/commands/schema-types.d.ts"
    },
    "./commands/db-inspect": {
      "import": "./dist/commands/db-inspect.js",
      "types": "./dist/commands/db-inspect.d.ts"
    },
    "./commands/prune": {
      "import": "./dist/commands/prune.js",
      "types": "./dist/commands/prune.d.ts"
    },
    "./commands/make-factory": {
      "import": "./dist/commands/make-factory.js",
      "types": "./dist/commands/make-factory.d.ts"
    },
    "./commands/make-seeder": {
      "import": "./dist/commands/make-seeder.js",
      "types": "./dist/commands/make-seeder.d.ts"
    },
    "./commands/make-resource": {
      "import": "./dist/commands/make-resource.js",
      "types": "./dist/commands/make-resource.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "tsc -p tsconfig.test.json && node --test \"dist-test/**/*.test.js\"",
    "clean": "rm -rf dist dist-test"
  },
  "rudderjs": {
    "provider": "NativeDatabaseProvider",
    "providerSubpath": "./native/provider",
    "stage": "infrastructure",
    "optional": true
  },
  "dependencies": {
    "@rudderjs/contracts": "workspace:^",
    "@rudderjs/database": "workspace:^"
  },
  "peerDependencies": {
    "@rudderjs/console": "workspace:^",
    "@rudderjs/core": "workspace:^",
    "better-sqlite3": "^12.0.0",
    "postgres": "^3.0.0",
    "mysql2": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@rudderjs/console": {
      "optional": true
    },
    "@rudderjs/core": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "postgres": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rudderjs/console": "workspace:^",
    "@rudderjs/core": "workspace:^",
    "@types/better-sqlite3": "^7.0.0",
    "@types/node": "^20.0.0",
    "better-sqlite3": "^12.0.0",
    "postgres": "^3.0.0",
    "mysql2": "^3.0.0",
    "typescript": "^5.4.0"
  },
  "author": "Suleiman Shahbari"
}
