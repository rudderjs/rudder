{
  "name": "@rudderjs/orm",
  "version": "1.12.11",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rudderjs/rudder",
    "directory": "packages/orm"
  },
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "files": [
    "dist",
    "boost"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./native": {
      "node": "./dist/native/index.js",
      "import": "./dist/native/index.js",
      "default": "./dist/native/index.js",
      "types": "./dist/native/index.d.ts"
    },
    "./doctor": {
      "import": "./dist/doctor.js",
      "default": "./dist/doctor.js",
      "types": "./dist/doctor.d.ts"
    },
    "./commands/migrate": {
      "import": "./dist/commands/migrate.js",
      "types": "./dist/commands/migrate.d.ts"
    },
    "./commands/prune": {
      "import": "./dist/commands/prune.js",
      "types": "./dist/commands/prune.d.ts"
    },
    "./commands/make-factory": {
      "import": "./dist/commands/make-factory.js",
      "types": "./dist/commands/make-factory.d.ts"
    },
    "./commands/make-seeder": {
      "import": "./dist/commands/make-seeder.js",
      "types": "./dist/commands/make-seeder.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/index.test.js dist-test/dirty.test.js dist-test/morph.test.js dist-test/morph-many-to-many.test.js dist-test/polymorphic-eager-load.test.js dist-test/belongs-to-many-pivot.test.js dist-test/pivot-deferred.test.js dist-test/whereHas.test.js dist-test/where-group.test.js dist-test/aggregate.test.js dist-test/seeder.test.js dist-test/prune.test.js dist-test/vector-cast.test.js dist-test/non-id-primary-key.test.js dist-test/model-registry-reregister.test.js dist-test/commands/migrate.test.js dist-test/commands/prune.test.js dist-test/native/compiler.test.js dist-test/native/compiler-write.test.js dist-test/native/compiler-relations.test.js dist-test/native/native-read.test.js dist-test/native/native-write.test.js dist-test/native/native-relations.test.js dist-test/native/native-transactions.test.js dist-test/native/provider.test.js dist-test/native/boolean-binding.test.js",
    "clean": "rm -rf dist"
  },
  "rudderjs": {
    "provider": "NativeDatabaseProvider",
    "providerSubpath": "./native",
    "stage": "infrastructure",
    "optional": true
  },
  "dependencies": {
    "@rudderjs/contracts": "workspace:^"
  },
  "peerDependencies": {
    "@rudderjs/console": "workspace:^",
    "@rudderjs/core": "workspace:^",
    "better-sqlite3": "^12.0.0"
  },
  "peerDependenciesMeta": {
    "@rudderjs/console": {
      "optional": true
    },
    "@rudderjs/core": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rudderjs/console": "workspace:^",
    "@rudderjs/core": "workspace:^",
    "@types/better-sqlite3": "^7.0.0",
    "@types/node": "^20.0.0",
    "better-sqlite3": "^12.0.0",
    "typescript": "^5.4.0"
  },
  "author": "Suleiman Shahbari"
}
