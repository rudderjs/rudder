{
  "name": "@rudderjs/database",
  "version": "1.5.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rudderjs/rudder",
    "directory": "packages/database"
  },
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "files": [
    "dist",
    "boost"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./sticky": {
      "node": "./dist/sticky.js",
      "import": "./dist/sticky.js",
      "default": "./dist/sticky.js",
      "types": "./dist/sticky.d.ts"
    },
    "./native": {
      "node": "./dist/native/index.js",
      "import": "./dist/native/index.js",
      "default": "./dist/native/index.js",
      "types": "./dist/native/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist",
    "test": "tsc -p tsconfig.test.json && node --test \"dist-test/**/*.test.js\""
  },
  "dependencies": {
    "@rudderjs/contracts": "workspace:^"
  },
  "peerDependencies": {
    "better-sqlite3": "^12.0.0",
    "postgres": "^3.0.0",
    "mysql2": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    },
    "postgres": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.0.0",
    "@types/node": "^20.0.0",
    "better-sqlite3": "^12.0.0",
    "typescript": "^5.4.0",
    "tsx": "^4.0.0"
  },
  "author": "Suleiman Shahbari"
}
