{
  "name": "@rudderjs/session",
  "version": "2.0.1",
  "rudderjs": {
    "provider": "SessionProvider",
    "stage": "infrastructure"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rudderjs/rudder",
    "directory": "packages/session"
  },
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "files": [
    "dist",
    "boost"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/index.test.js; EXIT=$?; rm -rf dist-test; exit $EXIT",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@rudderjs/contracts": "workspace:^",
    "@rudderjs/core": "workspace:^"
  },
  "peerDependencies": {
    "@rudderjs/vite": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@rudderjs/vite": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "ioredis": "^5.3.0"
  },
  "devDependencies": {
    "@rudderjs/vite": "workspace:^",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "author": "Suleiman Shahbari"
}
