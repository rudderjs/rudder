{
  "name": "@rudderjs/auth",
  "version": "6.6.0",
  "rudderjs": {
    "provider": "AuthProvider",
    "stage": "infrastructure",
    "depends": [
      "@rudderjs/session",
      "@rudderjs/hash"
    ]
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rudderjs/rudder",
    "directory": "packages/auth"
  },
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "files": [
    "dist",
    "boost",
    "views",
    "schema"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./routes": {
      "import": "./dist/routes.js",
      "types": "./dist/routes.d.ts"
    },
    "./gate-observers": {
      "import": "./dist/gate-observers.js",
      "types": "./dist/gate-observers.d.ts"
    },
    "./doctor": {
      "import": "./dist/doctor.js",
      "types": "./dist/doctor.d.ts"
    },
    "./views/react/Login": "./views/react/Login.tsx",
    "./views/react/Register": "./views/react/Register.tsx",
    "./views/react/ForgotPassword": "./views/react/ForgotPassword.tsx",
    "./views/react/ResetPassword": "./views/react/ResetPassword.tsx",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/index.test.js dist-test/middleware-and-verification-fixes.test.js dist-test/base-auth-controller-rate-limits.test.js dist-test/ws-context-runner.test.js dist-test/remember.test.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@rudderjs/console": "workspace:^",
    "@rudderjs/contracts": "workspace:^",
    "@rudderjs/core": "workspace:^"
  },
  "peerDependencies": {
    "@rudderjs/hash": "workspace:^",
    "@rudderjs/middleware": "workspace:^",
    "@rudderjs/router": "workspace:^",
    "@rudderjs/session": "workspace:^",
    "@rudderjs/view": "workspace:^",
    "@rudderjs/vite": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@rudderjs/hash": {
      "optional": false
    },
    "@rudderjs/middleware": {
      "optional": false
    },
    "@rudderjs/router": {
      "optional": false
    },
    "@rudderjs/session": {
      "optional": false
    },
    "@rudderjs/view": {
      "optional": false
    },
    "@rudderjs/vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rudderjs/hash": "workspace:^",
    "@rudderjs/middleware": "workspace:^",
    "@rudderjs/router": "workspace:^",
    "@rudderjs/session": "workspace:^",
    "@rudderjs/view": "workspace:^",
    "@rudderjs/vite": "workspace:^",
    "@rudderjs/cache": "workspace:^",
    "@types/node": "^20.0.0",
    "reflect-metadata": "^0.2.2",
    "typescript": "^5.4.0"
  },
  "author": "Suleiman Shahbari"
}
