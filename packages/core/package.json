{
  "name": "@rudderjs/core",
  "version": "1.7.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rudderjs/rudder",
    "directory": "packages/core"
  },
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "files": [
    "dist",
    "boost"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "./dist/index.js"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./commands/providers-discover": {
      "import": "./dist/commands/providers-discover.js",
      "types": "./dist/commands/providers-discover.d.ts"
    },
    "./commands/event-list": {
      "import": "./dist/commands/event-list.js",
      "types": "./dist/commands/event-list.d.ts"
    },
    "./commands/config-show": {
      "import": "./dist/commands/config-show.js",
      "types": "./dist/commands/config-show.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist",
    "test": "tsc -p tsconfig.test.json && cd dist-test && node --test"
  },
  "dependencies": {
    "@rudderjs/console": "workspace:^",
    "@rudderjs/contracts": "workspace:^",
    "@rudderjs/router": "workspace:^",
    "@rudderjs/support": "workspace:^",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "tsx": "^4.0.0"
  },
  "author": "Suleiman Shahbari"
}
