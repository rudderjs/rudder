{
  "name": "@rudderjs/vite",
  "version": "2.9.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rudderjs/rudder",
    "directory": "packages/vite"
  },
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "files": [
    "dist",
    "boost"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./page-context-enhancers": {
      "import": "./dist/page-context-enhancers.js",
      "default": "./dist/page-context-enhancers.js",
      "types": "./dist/page-context-enhancers.d.ts"
    },
    "./hooks/onCreatePageContext": {
      "import": "./dist/hooks/onCreatePageContext.js",
      "default": "./dist/hooks/onCreatePageContext.js",
      "types": "./dist/hooks/onCreatePageContext.d.ts"
    },
    "./hooks/onError": {
      "import": "./dist/hooks/onError.js",
      "default": "./dist/hooks/onError.js",
      "types": "./dist/hooks/onError.d.ts"
    },
    "./hooks/headersResponse": {
      "import": "./dist/hooks/headersResponse.js",
      "default": "./dist/hooks/headersResponse.js",
      "types": "./dist/hooks/headersResponse.d.ts"
    },
    "./commands/view-sync": {
      "import": "./dist/commands/view-sync.js",
      "default": "./dist/commands/view-sync.js",
      "types": "./dist/commands/view-sync.d.ts"
    },
    "./commands/routes-sync": {
      "import": "./dist/commands/routes-sync.js",
      "default": "./dist/commands/routes-sync.js",
      "types": "./dist/commands/routes-sync.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "tsc -p tsconfig.test.json && cd dist-test && node --test",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "vite": ">=5.0.0",
    "vike": ">=0.4.0",
    "@rudderjs/core": "workspace:^",
    "@vitejs/plugin-react": ">=4.0.0",
    "@vitejs/plugin-vue": ">=5.0.0",
    "vike-solid": ">=0.8.0"
  },
  "peerDependenciesMeta": {
    "@rudderjs/core": {
      "optional": true
    },
    "@vitejs/plugin-react": {
      "optional": true
    },
    "@vitejs/plugin-vue": {
      "optional": true
    },
    "vike-solid": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rudderjs/core": "workspace:^",
    "@types/node": "^20.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "typescript": "^5.4.0",
    "vike": "^0.4.239",
    "vike-solid": "^0.8.1",
    "vite": "^8.0.0",
    "vite-plugin-solid": "^2.11.12"
  },
  "author": "Suleiman Shahbari"
}
