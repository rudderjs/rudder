{
  "name": "@rudderjs/workspaces",
  "version": "0.0.1",
  "description": "AI workspace builder — departments, agents, knowledge base, orchestrator",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rudderjs/rudder",
    "directory": "packages/workspaces"
  },
  "type": "module",
  "files": ["dist", "schema"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/index.test.js; EXIT=$?; rm -rf dist-test; exit $EXIT",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@rudderjs/core": "workspace:*",
    "@rudderjs/ai": "workspace:*",
    "@rudderjs/orm": "workspace:*",
    "@rudderjs/panels": "workspace:*",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "@rudderjs/router": "workspace:*",
    "@rudderjs/broadcast": "workspace:*",
    "react": ">=18",
    "react-dom": ">=18",
    "three": ">=0.160.0",
    "@react-three/fiber": ">=8",
    "@react-three/drei": ">=9",
    "yjs": ">=13",
    "y-websocket": ">=2",
    "y-indexeddb": ">=9"
  },
  "peerDependenciesMeta": {
    "@rudderjs/router": { "optional": true },
    "@rudderjs/broadcast": { "optional": true },
    "three": { "optional": true },
    "@react-three/fiber": { "optional": true },
    "@react-three/drei": { "optional": true },
    "yjs": { "optional": true },
    "y-websocket": { "optional": true },
    "y-indexeddb": { "optional": true }
  },
  "devDependencies": {
    "@rudderjs/router": "workspace:*",
    "@rudderjs/broadcast": "workspace:*",
    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/three": "^0.175.0",
    "react": "^19.0.0",
    "three": "^0.175.0",
    "typescript": "^5.4.0"
  },
  "author": "Suleiman Shahbari"
}
