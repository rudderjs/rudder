  },
  "dependencies": {
    "@boostkit/core": "workspace:*",
    "@boostkit/mail": "workspace:*",
    "@boostkit/orm": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "tsx": "^4.0.0"
  }
}
