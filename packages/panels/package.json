{
  "name": "@boostkit/panels",
  "version": "0.0.2",
  "description": "Multi-panel admin and user-facing dashboard builder for BoostKit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/boostkitjs/boostkit",
    "directory": "packages/panels"
  },
  "type": "module",
  "files": [
    "dist",
    "pages"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/index.test.js; rm -rf dist-test",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@boostkit/core": "workspace:*",
    "@boostkit/router": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "author": "Suleiman Shahbari"
}
