{
  "name": "@boostkit/panels",
  "version": "0.0.3",
  "description": "Multi-panel admin and user-facing dashboard builder for BoostKit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/boostkitjs/boostkit",
    "directory": "packages/panels"
  },
  "type": "module",
  "files": [
    "dist",
    "pages",
    "schema"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/index.test.js; EXIT=$?; rm -rf dist-test; exit $EXIT",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@boostkit/core": "workspace:*",
    "@boostkit/router": "workspace:*",
    "quill-delta": "^5.1.0"
  },
  "peerDependencies": {
    "@boostkit/broadcast": "workspace:*",
    "@boostkit/live": "workspace:*",
    "@boostkit/storage": "workspace:*",
    "recharts": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@boostkit/storage": {
      "optional": true
    },
    "@boostkit/broadcast": {
      "optional": true
    },
    "@boostkit/live": {
      "optional": true
    },
    "recharts": {
      "optional": true
    }
  },
  "devDependencies": {
    "@boostkit/broadcast": "workspace:*",
    "@boostkit/live": "workspace:*",
    "@boostkit/storage": "workspace:*",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "typescript": "^5.4.0"
  },
  "author": "Suleiman Shahbari"
}
