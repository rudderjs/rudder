{
  "name": "@rudderjs/orm-prisma",
  "version": "0.0.11",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rudderjs/rudder",
    "directory": "packages/orm-prisma"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/index.test.js; EXIT=$?; rm -rf dist-test; exit $EXIT",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@rudderjs/core": "workspace:*",
    "@rudderjs/orm": "workspace:*",
    "@prisma/client": "^7.0.0",
    "@rudderjs/contracts": "workspace:*"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.0.0",
    "@prisma/adapter-better-sqlite3": "^7.0.0",
    "pg": "^8.0.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@libsql/client": "^0.15.0",
    "@prisma/adapter-libsql": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/better-sqlite3": "^7.0.0",
    "@types/pg": "^8.0.0",
    "prisma": "^7.0.0",
    "typescript": "^5.4.0"
  },
  "author": "Suleiman Shahbari"
}
