{
  "name": "@forge/orm-prisma",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@forge/orm": "workspace:*",
    "@prisma/client": "^5.0.0"
  },
  "optionalDependencies": {
    "pg": "^8.0.0",
    "@prisma/adapter-pg": "^6.0.0",
    "@libsql/client": "^0.15.0",
    "@prisma/adapter-libsql": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.0.0",
    "prisma": "^5.0.0",
    "typescript": "^5.4.0"
  }
}