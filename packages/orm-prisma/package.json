{
  "name": "@rudderjs/orm-prisma",
  "version": "1.9.0",
  "rudderjs": {
    "provider": "DatabaseProvider",
    "stage": "infrastructure",
    "optional": true
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rudderjs/rudder",
    "directory": "packages/orm-prisma"
  },
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "files": [
    "dist",
    "boost"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./doctor": {
      "import": "./dist/doctor.js",
      "types": "./dist/doctor.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/index.test.js dist-test/whereHas.test.js dist-test/where-group.test.js dist-test/aggregate.test.js dist-test/vector.test.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@rudderjs/console": "workspace:^",
    "@rudderjs/core": "workspace:^",
    "@rudderjs/orm": "workspace:^",
    "@rudderjs/contracts": "workspace:^",
    "@rudderjs/support": "workspace:^"
  },
  "peerDependencies": {
    "@prisma/client": "^7.0.0",
    "@rudderjs/ai": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@prisma/client": {
      "optional": true
    },
    "@rudderjs/ai": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.0.0",
    "@prisma/adapter-better-sqlite3": "^7.0.0",
    "pg": "^8.0.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@libsql/client": "^0.17.0",
    "@prisma/adapter-libsql": "^7.0.0",
    "mariadb": "^3.0.0",
    "@prisma/adapter-mariadb": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/better-sqlite3": "^7.0.0",
    "@types/pg": "^8.0.0",
    "prisma": "^7.0.0",
    "typescript": "^5.4.0"
  },
  "author": "Suleiman Shahbari"
}
