{
  "name": "@rudderjs/queue",
  "version": "4.2.2",
  "rudderjs": {
    "provider": "QueueProvider",
    "stage": "feature"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rudderjs/rudder",
    "directory": "packages/queue"
  },
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "files": [
    "dist",
    "boost"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./observers": {
      "import": "./dist/observers.js",
      "types": "./dist/observers.d.ts"
    },
    "./native": {
      "node": "./dist/native/index.js",
      "import": "./dist/native/index.js",
      "default": "./dist/native/index.js",
      "types": "./dist/native/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/index.test.js dist-test/job-middleware.test.js dist-test/unique.test.js dist-test/batch.test.js dist-test/chain.test.js dist-test/closure.test.js dist-test/serialize.test.js dist-test/execute.test.js dist-test/native/database-queue.test.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@rudderjs/core": "workspace:^"
  },
  "peerDependencies": {
    "@rudderjs/cache": "workspace:^",
    "@rudderjs/router": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@rudderjs/cache": {
      "optional": true
    },
    "@rudderjs/router": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rudderjs/cache": "workspace:^",
    "@rudderjs/orm": "workspace:^",
    "@rudderjs/router": "workspace:^",
    "@types/better-sqlite3": "^7.0.0",
    "@types/node": "^20.0.0",
    "better-sqlite3": "^12.0.0",
    "typescript": "^5.4.0"
  },
  "author": "Suleiman Shahbari"
}
