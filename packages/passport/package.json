{
  "name": "@rudderjs/passport",
  "version": "2.0.5",
  "rudderjs": {
    "provider": "PassportProvider",
    "stage": "infrastructure",
    "depends": [
      "@rudderjs/auth",
      "@rudderjs/orm-prisma"
    ]
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rudderjs/rudder",
    "directory": "packages/passport"
  },
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "files": [
    "dist",
    "schema",
    "boost"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./routes": {
      "import": "./dist/routes.js",
      "types": "./dist/routes.d.ts"
    },
    "./commands/make-passport-client": {
      "import": "./dist/commands/make-passport-client.js",
      "types": "./dist/commands/make-passport-client.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist",
    "test": "tsc -p tsconfig.test.json && node --test \"dist-test/**/*.test.js\""
  },
  "dependencies": {
    "@rudderjs/core": "workspace:^",
    "@rudderjs/contracts": "workspace:^",
    "@rudderjs/orm": "workspace:^"
  },
  "devDependencies": {
    "@rudderjs/console": "workspace:^",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "tsx": "^4.0.0"
  },
  "author": "Suleiman Shahbari"
}
