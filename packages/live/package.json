{
  "name": "@rudderjs/live",
  "version": "0.0.5",
  "rudderjs": {
    "provider": "LiveProvider",
    "stage": "feature"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rudderjs/rudder",
    "directory": "packages/live"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/index.test.js; EXIT=$?; rm -rf dist-test; exit $EXIT"
  },
  "dependencies": {
    "@rudderjs/core": "workspace:*",
    "yjs": "^13.6.0",
    "ws": "^8.0.0",
    "lib0": "^0.2.0"
  },
  "optionalDependencies": {
    "ioredis": "^5.3.0",
    "@prisma/client": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "author": "Suleiman Shahbari"
}
