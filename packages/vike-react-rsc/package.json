    "@vitejs/plugin-rsc": "0.5.26",
    "react-streaming": "^0.4.12"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsdown": "^0.6.10",
    "typescript": "^5.4.0",
    "vike": "^0.4.257",
    "vite": "^8.0.0",
    "vitefu": "^1.1.1"
