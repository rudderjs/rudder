{
  "name": "@rudderjs/mail",
  "version": "1.0.4",
  "rudderjs": {
    "provider": "MailProvider",
    "stage": "feature"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rudderjs/rudder",
    "directory": "packages/mail"
  },
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "files": [
    "dist",
    "boost"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "tsc -p tsconfig.test.json && cd dist-test && node --experimental-test-module-mocks --test",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@rudderjs/core": "workspace:^"
  },
  "optionalDependencies": {
    "nodemailer": "^6.9.0"
  },
  "devDependencies": {
    "@rudderjs/queue": "workspace:*",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "author": "Suleiman Shahbari"
}
