model Media {
  id        String   @id @default(cuid())
  name      String                        // display name (original filename)
  type      String   @default("file")     // "file" | "folder"
  mime      String?                       // MIME type (null for folders)
  size      Int?                          // file size in bytes (null for folders)
  disk      String   @default("public")   // storage disk name
  directory String   @default("")         // storage path (e.g. "media/abc123")
  filename  String   @default("")         // stored filename (e.g. "original.webp")

  // Image-specific
  width     Int?
  height    Int?
  focalX    Float?                        // 0.0–1.0 focal point
  focalY    Float?                        // 0.0–1.0 focal point

  // Conversions (generated thumbnails/sizes)
  conversions Json  @default("[]")        // [{ name, filename, width, height, size, format }]

  // Custom metadata (alt text, caption, credit, etc.)
  alt       String?
  meta      Json    @default("{}")

  // Folder hierarchy
  parentId  String?
  parent    Media?  @relation("MediaTree", fields: [parentId], references: [id])
  children  Media[] @relation("MediaTree")

  // Ownership / scope
  scope     String  @default("shared")    // "shared" | "private"
  userId    String?                       // owner (null = shared)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([scope, userId])
  @@index([type])
  @@map("media")
}
