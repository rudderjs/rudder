  },
  "dependencies": {
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "@forge/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/reflect-metadata": "^0.1.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
