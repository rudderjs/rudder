{
  "name": "@rudderjs/orm-drizzle",
  "version": "1.11.0",
  "description": "Drizzle ORM adapter for RudderJS. Implements OrmAdapterProvider / OrmAdapter / QueryBuilder<T> using Drizzle's SQL-like fluent API.",
  "rudderjs": {
    "provider": "DatabaseProvider",
    "stage": "infrastructure",
    "optional": true
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rudderjs/rudder",
    "directory": "packages/orm-drizzle"
  },
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "files": [
    "dist",
    "boost"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./doctor": {
      "import": "./dist/doctor.js",
      "types": "./dist/doctor.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "tsc -p tsconfig.test.json && cd dist-test && node --test",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@rudderjs/console": "workspace:^",
    "@rudderjs/contracts": "workspace:^",
    "@rudderjs/core": "workspace:^",
    "@rudderjs/orm": "workspace:^",
    "@rudderjs/support": "workspace:^",
    "drizzle-orm": "^0.45.2"
  },
  "peerDependencies": {
    "@rudderjs/ai": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@rudderjs/ai": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@libsql/client": "^0.15.0",
    "better-sqlite3": "^12.0.0",
    "mysql2": "^3.11.0",
    "postgres": "^3.0.0"
  },
  "devDependencies": {
    "@rudderjs/database": "workspace:^",
    "@types/better-sqlite3": "^7.0.0",
    "@types/node": "^20.0.0",
    "kysely": "^0.28.17",
    "typescript": "^5.4.0"
  },
  "author": "Suleiman Shahbari"
}
