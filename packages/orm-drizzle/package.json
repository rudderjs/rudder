{
  "name": "@boostkit/orm-drizzle",
  "version": "0.0.2",
  "description": "Drizzle ORM adapter for BoostKit. Implements OrmAdapterProvider / OrmAdapter / QueryBuilder<T> using Drizzle's SQL-like fluent API.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/boostkitjs/boostkit",
    "directory": "packages/orm-drizzle"
  },
  "type": "module",
  "files": ["dist"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@boostkit/orm": "workspace:*",
    "drizzle-orm": "^0.38.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.0.0",
    "@libsql/client": "^0.15.0",
    "postgres": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/better-sqlite3": "^7.0.0",
    "typescript": "^5.4.0"
  }
}
