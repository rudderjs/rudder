diff --git a/dist/esm/runtime/importServerProductionEntry.js b/dist/esm/runtime/importServerProductionEntry.js
index f9477b67cbe949b475e6ea70ab9eae843e3b626f..2fc4008665a4a0f21335dfebb6d6825ae8a7cf2d 100644
--- a/dist/esm/runtime/importServerProductionEntry.js
+++ b/dist/esm/runtime/importServerProductionEntry.js
@@ -74,5 +74,9 @@ function isServerEntryOutsideOfCwd(paths) {
         return null;
     serverEntryFilePath = toPosixPath(serverEntryFilePath);
     assertPosixPath(cwd);
-    return !serverEntryFilePath.startsWith(cwd);
+    // RudderJS patch: compare with a trailing separator so a sibling whose dir name
+    // shares this app's prefix (e.g. cwd `/repo/playground` vs `/repo/playground-rsc`)
+    // isn't mistaken for being inside cwd. Without it, concurrent monorepo builds can
+    // import the wrong app's clobbered server entry from the shared autoImporter.js.
+    return !serverEntryFilePath.startsWith(cwd.endsWith('/') ? cwd : cwd + '/');
 }
