{
  "name": "@rudderjs/benchmarks",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Comparative query-layer ORM benchmark suite — RudderJS native engine vs Prisma vs Drizzle on an identical schema + dataset, on SQLite AND Postgres (§14 #11). Never published.",
  "scripts": {
    "bench:setup": "node src/setup.mjs",
    "bench": "node src/run.mjs",
    "bench:parity": "node src/parity.mjs",
    "bench:report": "node src/report.mjs",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "bench:pg:setup": "BENCH_ENGINE=postgres node src/setup.mjs",
    "bench:pg": "BENCH_ENGINE=postgres node src/run.mjs",
    "bench:pg:parity": "BENCH_ENGINE=postgres node src/parity.mjs",
    "bench:pg:report": "BENCH_ENGINE=postgres node src/report.mjs",
    "prisma:generate:pg": "prisma generate --schema=prisma/schema.postgres.prisma"
  },
  "devDependencies": {
    "@prisma/adapter-better-sqlite3": "^7.0.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@prisma/client-runtime-utils": "^7.0.0",
    "@rudderjs/database": "workspace:*",
    "@rudderjs/orm": "workspace:*",
    "better-sqlite3": "^12.0.0",
    "drizzle-orm": "^0.45.0",
    "mitata": "^1.0.34",
    "pg": "^8.13.0",
    "postgres": "^3.4.0",
    "prisma": "^7.0.0"
  }
}
