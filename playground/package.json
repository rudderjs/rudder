{
  "name": "forge-playground",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vike dev",
    "dev:clean": "pids=$(lsof -ti :24678 -ti :3000 2>/dev/null); if [ -n \"$pids\" ]; then kill -9 $pids; fi; vike dev",
    "build": "vike build",
    "start": "node ./dist/server/index.mjs",
    "preview": "node ./dist/server/index.mjs",
    "typecheck": "tsc --noEmit",
    "artisan": "tsx node_modules/@forge/cli/src/index.ts"
  },
  "dependencies": {
    "@forge/auth-better-auth": "workspace:*",
    "@forge/cache": "workspace:*",
    "@forge/core": "workspace:*",
    "@forge/schedule": "workspace:*",
    "@forge/storage": "workspace:*",
    "@forge/events": "workspace:*",
    "@forge/mail": "workspace:*",
    "@forge/mail-nodemailer": "workspace:*",
    "@forge/queue": "workspace:*",
    "@forge/rate-limit": "workspace:*",
    "@forge/di": "workspace:*",
    "@forge/middleware": "workspace:*",
    "@forge/orm": "workspace:*",
    "@forge/orm-prisma": "workspace:*",
    "@forge/router": "workspace:*",
    "@forge/server": "workspace:*",
    "@forge/server-hono": "workspace:*",
    "@forge/support": "workspace:*",
    "@forge/validation": "workspace:*",
    "@photonjs/hono": "^0.1.12",
    "@prisma/adapter-better-sqlite3": "^7.0.0",
