    "lucide-react": "^0.575.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reflect-metadata": "^0.2.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "vike": "^0.4.239",
