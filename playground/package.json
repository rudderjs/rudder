{
  "name": "rudderjs-playground",
  "version": "0.0.7",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vike dev",
    "dev:clean": "pids=$(lsof -ti :24678 -ti :3000 2>/dev/null); if [ -n \"$pids\" ]; then kill -9 $pids; fi; vike dev",
    "build": "vike build",
    "start": "node ./dist/server/index.mjs",
    "preview": "pids=$(lsof -ti :3000 2>/dev/null); if [ -n \"$pids\" ]; then kill -9 $pids; fi; node ./dist/server/index.mjs",
    "typecheck": "tsc --noEmit",
    "rudder": "tsx node_modules/@rudderjs/cli/src/index.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
