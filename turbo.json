{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "@rudderjs/docs#build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".vitepress/dist/**"
      ]
    },
    // The Vike apps share `@brillout/vite-plugin-server-entry`'s autoImporter in
    // node_modules; building them concurrently races on that shared file (one
    // app's prerender imports another's not-yet-built dist/server/entry.mjs →
    // "Cannot find module", intermittently failing the Release). These artificial
    // dependsOn edges force playground → playground-web → playground-rsc to build
    // serially. Packages/docs still build in parallel; cached app builds complete
    // instantly, so this is a no-op on cache hits.
    "rudderjs-playground-web#build": {
      "dependsOn": [
        "^build",
        "rudderjs-playground#build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "rudderjs-playground-rsc#build": {
      "dependsOn": [
        "^build",
        "rudderjs-playground-web#build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    // The comparative ORM benchmark suite (@rudderjs/benchmarks). Timing must
    // NEVER be cached, and it runs against compiled dist/ (prod builds only,
    // never tsx source) — hence cache:false + dependsOn ^build.
    "bench": {
      "cache": false,
      "dependsOn": [
        "^build"
      ]
    },
    "lint": {},
    "typecheck": {
      "dependsOn": [
        "^build"
      ]
    },
    "clean": {
      "cache": false
    },
    // PG_TEST_URL / MYSQL_TEST_URL gate the live-database conformance suites
    // (orm native drivers, orm-drizzle r/w split, json-where, …). They must be
    // declared in `env` — turbo 2 runs tasks in strict env mode, so undeclared
    // vars are STRIPPED from the child process and every live test silently
    // skips (the CI orm-pg/orm-mysql jobs were green-by-skip before this).
    // `env` (not `passThroughEnv`) so the vars are part of the cache key: a
    // sqlite-only cached green can't be replayed for a live-enabled run.
    "test": {
      "dependsOn": [
        "^build"
      ],
      "env": [
        "PG_TEST_URL",
        "MYSQL_TEST_URL"
      ],
      "outputs": []
    },
    "docs:dev": {
      "cache": false,
      "persistent": true
    },
    "docs:build": {
      "dependsOn": ["^build"],
      "outputs": [".vitepress/dist/**"]
    }
  }
}
