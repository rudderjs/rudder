{
  "name": "playground-multi",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vike dev",
    "dev:clean": "pids=$(lsof -ti :24678 -ti :3000 2>/dev/null); if [ -n \"$pids\" ]; then kill -9 $pids; fi; vike dev",
    "build": "vike build",
    "start": "node ./dist/server/index.mjs",
    "preview": "node ./dist/server/index.mjs",
    "typecheck": "tsc --noEmit",
    "rudder": "tsx node_modules/@rudderjs/cli/src/index.ts"
  },
  "dependencies": {
    "@rudderjs/rudder": "workspace:*",
    "@rudderjs/vite": "workspace:*",
    "@rudderjs/auth": "workspace:*",
    "@rudderjs/cache": "workspace:*",
    "@rudderjs/contracts": "workspace:*",
    "@rudderjs/core": "workspace:*",
    "@rudderjs/middleware": "workspace:*",
    "@rudderjs/orm": "workspace:*",
    "@rudderjs/orm-prisma": "workspace:*",
    "@rudderjs/queue": "workspace:*",
    "@rudderjs/router": "workspace:*",
    "@rudderjs/schedule": "workspace:*",
    "@rudderjs/server-hono": "workspace:*",
    "@rudderjs/session": "workspace:*",
    "@rudderjs/storage": "workspace:*",
    "@rudderjs/support": "workspace:*",
    "@rudderjs/mail": "workspace:*",
    "@rudderjs/notification": "workspace:*",
    "@prisma/client": "^7.0.0",
    "dotenv": "^16.4.0",
    "reflect-metadata": "^0.2.2",
    "vike": "^0.4.257",
    "@vikejs/hono": "^0.2.0",
    "zod": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vike-react": "^0.6.20",
    "vue": "^3.5.0",
    "vike-vue": "latest",
    "solid-js": "^1.9.0",
    "vike-solid": "latest",
    "tailwindcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "better-sqlite3": "^12.0.0"
  },
  "devDependencies": {
    "@rudderjs/cli": "workspace:*",
    "@types/node": "^20.0.0",
    "prisma": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vite": "^7.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "tw-animate-css": "^1.4.0",
    "@types/better-sqlite3": "^7.6.0"
  }
}
