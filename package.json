{
  "name": "rudderjs",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "build": "turbo run build",
    "build:publish": "turbo run build --filter=./packages/* --filter=./create-rudder --filter=./create-rudder-app",
    "dev": "turbo run dev",
    "lint": "eslint \"packages/*/src/**/*.{ts,tsx}\"",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "rudder": "tsx packages/cli/src/index.ts",
    "test": "turbo run test",
    "docs:dev": "turbo run docs:dev --filter=@rudderjs/docs",
    "docs:build": "turbo run docs:build --filter=@rudderjs/docs",
    "docs:preview": "cd docs && pnpm preview",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "pnpm build:publish && pnpm changeset publish",
    "test:client-bundle": "node scripts/client-bundle-smoke.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "msgpackr-extract",
      "protobufjs",
      "better-sqlite3",
      "sharp"
    ],
    "overrides": {
      "tsdown>rolldown": "1.0.0-beta.8",
      "vike": "0.4.257",
      "@types/node": "20.19.35",
      "hono": "^4.12.4",
      "protobufjs@7": "^7.6.1",
      "protobufjs@8": "^8.4.2",
      "@google/genai>ws": "^8.21.0",
      "express>qs": "^6.15.2",
      "postcss": "^8.5.10",
      "defu": "^6.1.5",
      "lodash": "^4.18.0",
      "effect": "^3.20.0",
      "diff": "^8.0.3",
      "@hono/node-server": "^1.19.14",
      "valibot": "^1.2.0"
    },
    "patchedDependencies": {
      "vike@0.4.257": "patches/vike@0.4.257.patch"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "tsx": "^4.21.0",
    "turbo": "^2.9.16",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.57.1"
  }
}
