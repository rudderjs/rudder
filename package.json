{
  "name": "rudderjs",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "eslint \"packages/*/src/**/*.{ts,tsx}\"",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "rudder": "tsx packages/cli/src/index.ts",
    "test": "turbo run test",
    "docs:dev": "turbo run docs:dev --filter=@rudderjs/docs",
    "docs:build": "turbo run docs:build --filter=@rudderjs/docs",
    "docs:preview": "cd docs && pnpm preview",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "pnpm build && pnpm changeset publish",
    "test:client-bundle": "node scripts/client-bundle-smoke.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "msgpackr-extract",
      "protobufjs",
      "better-sqlite3",
      "sharp"
    ],
    "overrides": {
      "tsdown>rolldown": "1.0.0-beta.8",
      "vike": "0.4.257",
      "@types/node": "20.19.35"
    },
    "patchedDependencies": {
      "vike@0.4.257": "patches/vike@0.4.257.patch"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "tsx": "^4.21.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.57.1"
  }
}
